{
  "name": "vgc-multicalc",
  "version": "1.18.12",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build && cp dist/browser/404/index.html dist/browser/404.html && node scripts/update-sitemap.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --coverage --watch=false --exclude='**/*.performance.spec.ts'",
    "test-watch": "ng test --coverage --exclude='**/*.performance.spec.ts'",
    "perf": "ng test --include='**/*.performance.spec.ts' --watch=false",
    "e2e-test": "npx cypress run --quiet; exit_code=$?; if [ $exit_code -eq 0 ]; then echo '✅ Tests PASSED successfully!\n'; else echo '❌ Tests FAILED.\n'; fi; exit $exit_code",
    "lint": "ng lint",
    "formatter": "npx prettier . --check",
    "check": "npm run lint && npm run formatter"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "22.0.4",
    "@angular/cdk": "22.0.2",
    "@angular/common": "22.0.4",
    "@angular/compiler": "22.0.4",
    "@angular/core": "22.0.4",
    "@angular/forms": "22.0.4",
    "@angular/material": "22.0.2",
    "@angular/platform-browser": "22.0.4",
    "@angular/platform-server": "22.0.4",
    "@angular/router": "22.0.4",
    "@angular/service-worker": "22.0.4",
    "@angular/ssr": "22.0.4",
    "@ngrx/signals": "21.1.1",
    "@robsonbittencourt/calc": "0.11.18",
    "dedent": "1.7.2",
    "koffing": "1.0.0",
    "pdf-lib": "1.17.1",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular/build": "22.0.4",
    "@angular/cli": "22.0.4",
    "@angular/compiler-cli": "22.0.4",
    "@eslint/js": "10.0.1",
    "@vitest/coverage-v8": "4.1.9",
    "angular-eslint": "22.0.0",
    "cypress": "15.18.0",
    "cypress-real-events": "1.15.0",
    "eslint": "10.6.0",
    "istanbul-lib-instrument": "6.0.3",
    "jsdom": "29.1.1",
    "prettier": "3.8.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vitest": "4.1.9"
  },
  "overrides": {
    "@ngrx/signals": {
      "@angular/common": "$@angular/common",
      "@angular/core": "$@angular/core"
    }
  }
}
