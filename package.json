{
  "name": "vgc-multicalc",
  "version": "1.16.4",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build && cp dist/browser/404/index.html dist/browser/404.html && node scripts/update-sitemap.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --code-coverage --watch=false --exclude='**/*.performance.spec.ts'",
    "test-watch": "ng test --code-coverage --exclude='**/*.performance.spec.ts'",
    "perf": "ng test --include='**/*.performance.spec.ts' --watch=false",
    "e2e-test": "npx cypress run --quiet; exit_code=$?; if [ $exit_code -eq 0 ]; then echo '✅ Tests PASSED successfully!\n'; else echo '❌ Tests FAILED.\n'; fi; exit $exit_code",
    "lint": "ng lint",
    "formatter": "npx prettier . --check",
    "check": "npm run lint && npm run formatter"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.15",
    "@angular/cdk": "21.2.13",
    "@angular/common": "21.2.15",
    "@angular/compiler": "21.2.15",
    "@angular/core": "21.2.15",
    "@angular/forms": "21.2.15",
    "@angular/material": "21.2.13",
    "@angular/platform-browser": "21.2.15",
    "@angular/platform-browser-dynamic": "21.2.15",
    "@angular/platform-server": "^21.2.15",
    "@angular/router": "21.2.15",
    "@angular/service-worker": "21.2.15",
    "@angular/ssr": "21.2.13",
    "@ngrx/signals": "21.1.0",
    "@robsonbittencourt/calc": "0.11.13",
    "dedent": "1.7.2",
    "koffing": "1.0.0",
    "pdf-lib": "1.17.1",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular/build": "21.2.13",
    "@angular/cli": "21.2.13",
    "@angular/compiler-cli": "21.2.15",
    "@eslint/js": "^10.0.1",
    "@types/jasmine": "5.1.13",
    "angular-cli-ghpages": "3.0.3",
    "angular-eslint": "21.4.0",
    "cypress": "15.16.0",
    "cypress-real-events": "1.15.0",
    "eslint": "10.4.0",
    "jasmine-core": "5.13.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.2.0",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.0"
  },
  "overrides": {
    "@ngrx/signals": {
      "@angular/common": "$@angular/common",
      "@angular/core": "$@angular/core"
    }
  }
}
